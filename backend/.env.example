PORT=5000
MONGODB_URI=mongodb://localhost:27017/enterprise_task_manager
JWT_ACCESS_SECRET=your_jwt_access_secret_here_must_be_strong
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_must_be_strong
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Nodemailer / Gmail SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Enterprise Task Manager <noreply@example.com>

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Client URL (for CORS and redirects)
CLIENT_URL=http://localhost:5173
NODE_ENV=development
